# Azure OpenAI Configuration - Main Generation (16K tokens)
AZURE_AI_TOKEN=your-azure-api-key-here
AZURE_AI_ENDPOINT_URL=https://your-resource.openai.azure.com/
AZURE_AI_DEPLOYMENT_NAME=gpt-4
AZURE_AI_APP_VERSION=2024-08-01-preview

# Planning LLM Configuration (2K tokens - for JSON planning outputs)
PLANNING_API_KEY=your-planning-api-key-here
PLANNING_MODEL=openai/gpt-4o-mini

# Update/Edit LLM Configuration (4K tokens - for HTML/CSS editing)
UPDATE_API_KEY=your-update-api-key-here
UPDATE_MODEL=gpt-4
UPDATE_API_BASE=https://your-resource.openai.azure.com/
UPDATE_API_VERSION=2024-08-01-preview

# Legacy OpenAI API Configuration (if needed)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
DALLE_MODEL=dall-e-3

# Base URL Configuration (for image URLs in generated HTML)
# This is used to convert relative image paths to full URLs for iframe compatibility
BASE_URL=http://localhost:8000

# Images configuration
IMAGES_PATH=/path/to/your/fallback/images
IMAGES_URL=http://localhost:8000/theme-images

# ── Export / Local Save Path ──────────────────────────────────────────────────
# Optional: Set a custom path where generated websites will be EXPORTED.
# Export is triggered ONLY when the user explicitly calls: POST /api/export/{folder_name}
# Websites are still always saved internally to Backend/webtemplates/ after generation.
# Leave blank or omit to disable the export feature.
# Windows example: OUTPUT_PATH=C:\Users\YourName\Desktop\MyWebsites
# Linux/Mac example: OUTPUT_PATH=/home/yourname/exported-websites
OUTPUT_PATH=